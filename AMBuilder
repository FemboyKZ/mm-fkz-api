import os

for sdk_target in MMSPlugin.sdk_targets:
    sdk = sdk_target.sdk
    cxx = sdk_target.cxx

    binary = MMSPlugin.HL2Library(
        builder, cxx, f'{MMSPlugin.metadata["name"]}.{sdk["name"]}', sdk
    )

    binary.sources += [
        "src/plugin.cpp",
        "src/globals.cpp",
        "src/config.cpp",
        "src/player_manager.cpp",
        "src/server_info.cpp",
        "src/http_client.cpp",
        "src/json_builder.cpp",
        "src/reporter.cpp",
        "src/cross_chat.cpp",
        "src/database.cpp",
        "src/api.cpp",
        "src/cs2kz.cpp",
    ]

    # SayText2 (cross-chat) lives in usermessages.proto, which imports
    # networkbasetypes.proto -> network_connection.proto.
    protoc_builder = builder.tools.Protoc(
        protoc=sdk_target.protoc,
        sources=[
            os.path.join(sdk["path"], "common", "network_connection.proto"),
            os.path.join(sdk["path"], "common", "networkbasetypes.proto"),
            os.path.join(sdk["path"], "game", "shared", "usermessages.proto"),
        ],
    )
    protoc_builder.protoc.includes += [
        os.path.join(sdk["path"], "common"),
        os.path.join(sdk["path"], "game", "shared"),
    ]

    binary.custom = [protoc_builder]

    nodes = builder.Add(binary)
    MMSPlugin.binaries += [nodes]
